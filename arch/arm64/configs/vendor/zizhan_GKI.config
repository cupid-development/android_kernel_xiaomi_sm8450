# Fingerprint
CONFIG_FINGERPRINT_FPC_1540=m
CONFIG_FINGERPRINT_GOODIX_3626=m

# Power
CONFIG_MI_CHARGER_M81=y
CONFIG_MI_THERMAL_MULTI_CHARGE=y

# Regulators
CONFIG_REGULATOR_WL2866D=m

# Touchscreen
CONFIG_TOUCHSCREEN_ST_FTS_V521_SPI=m
